---
import { SITE_TITLE, SITE_TAGLINE, SOCIALS, NAV_LINKS } from "@/consts";
const year = new Date().getFullYear();
---

<footer
  class="border-t border-ink-200/70 bg-ink-50/50 dark:border-ink-800/70 dark:bg-ink-950"
>
  <div
    class="mx-auto flex max-w-5xl flex-col gap-6 px-4 py-10 sm:px-6 md:flex-row md:items-center md:justify-between"
  >
    <div>
      <p class="font-semibold text-ink-900 dark:text-white">{SITE_TITLE}</p>
      <p class="text-sm text-ink-500 dark:text-ink-400">{SITE_TAGLINE}</p>
    </div>

    <nav
      class="flex flex-wrap gap-x-5 gap-y-2 text-sm"
      aria-label="Footer navigation"
    >
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="text-ink-600 transition hover:text-azure-600 dark:text-ink-300 dark:hover:text-azure-400"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/rss.xml"
        class="text-ink-600 transition hover:text-azure-600 dark:text-ink-300 dark:hover:text-azure-400"
        >RSS</a
      >
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={SOCIALS.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="text-ink-500 transition hover:text-azure-600 dark:text-ink-400 dark:hover:text-azure-400"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"
          ><path
            d="M4.98 3.5A2.5 2.5 0 100 3.51 2.5 2.5 0 004.98 3.5zM.24 8.02h4.5V24H.24V8.02zM8.24 8.02h4.31v2.18h.06c.6-1.14 2.07-2.34 4.26-2.34C21.6 7.86 24 10.1 24 14.6V24h-4.5v-8.3c0-1.98-.04-4.52-2.76-4.52-2.76 0-3.18 2.16-3.18 4.38V24H8.24V8.02z"
          ></path></svg
        >
      </a>
      <a
        href={SOCIALS.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-ink-500 transition hover:text-azure-600 dark:text-ink-400 dark:hover:text-azure-400"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"
          ><path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.48l-.01-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.9 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.35 9.35 0 015 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.79-4.57 5.04.36.32.68.94.68 1.9l-.01 2.82c0 .27.18.59.69.48A10.02 10.02 0 0022 12.25C22 6.58 17.52 2 12 2z"
          ></path></svg
        >
      </a>
    </div>
  </div>

  <div class="border-t border-ink-200/70 dark:border-ink-800/70">
    <p
      class="mx-auto max-w-5xl px-4 py-4 text-center text-xs text-ink-500 sm:px-6 dark:text-ink-500"
    >
      &copy; {year} {SITE_TITLE}. Built with Astro &amp; hosted on Azure Static Web
      Apps.
    </p>
  </div>
</footer>
