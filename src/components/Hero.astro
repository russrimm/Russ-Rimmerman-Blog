---
import { SITE_TAGLINE } from "@/consts";

interface Props {
  /** Curated topic chips linking into real tag pages. */
  topics?: { label: string; href: string }[];
}

const { topics = [] } = Astro.props;
const displayTopics = topics.slice(0, 4);
---

<section class="relative overflow-hidden">
  <div class="bg-grid absolute inset-0 -z-10 opacity-60"></div>
  <div
    class="absolute -top-32 left-1/3 -z-10 h-80 w-[40rem] -translate-x-1/2 rounded-full bg-azure-500/15 blur-3xl dark:bg-azure-600/15"
    aria-hidden="true"
  >
  </div>

  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24 lg:py-28">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-azure-200 bg-azure-50 px-3 py-1 text-xs font-medium text-azure-700 dark:border-ink-700 dark:bg-ink-800 dark:text-azure-300"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-teal-500"></span>
      {SITE_TAGLINE}
    </span>

    <h1
      class="mt-6 max-w-3xl text-balance text-5xl font-bold tracking-tight text-ink-900 sm:text-6xl dark:text-white"
    >
      Where I dump what I learn, to{" "}
      <span class="text-azure-600 dark:text-azure-400">help you</span>
    </h1>

    <p
      class="mt-6 max-w-2xl text-pretty text-lg text-ink-600 sm:text-xl sm:leading-relaxed dark:text-ink-300"
    >
      Field-tested guidance on Azure, identity, Copilot, agents, and modern
      development — written by Russ Rimmerman, Principal Cloud Solution
      Architect at Microsoft.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-4">
      <a
        href="/blog"
        class="rounded-lg bg-azure-600 px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-azure-700 focus-visible:ring-2 focus-visible:ring-azure-500/40"
      >
        Read the latest
      </a>
      <a
        href="/topics"
        class="rounded-lg border border-ink-300 px-6 py-3.5 text-sm font-semibold text-ink-700 transition hover:border-azure-400 hover:text-azure-600 dark:border-ink-700 dark:text-ink-200 dark:hover:border-azure-500 dark:hover:text-azure-400"
      >
        Browse by topic
      </a>
    </div>

    {
      displayTopics.length > 0 && (
        <nav class="mt-10" aria-label="Popular topics">
          <ul class="flex flex-wrap gap-2">
            {displayTopics.map((topic) => (
              <li>
                <a
                  href={topic.href}
                  class="inline-flex items-center rounded-full border border-ink-200 bg-white px-4 py-2.5 text-sm font-medium text-ink-600 transition hover:border-azure-400 hover:text-azure-600 sm:px-3.5 sm:py-1.5 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-300 dark:hover:border-azure-500 dark:hover:text-azure-400"
                >
                  {topic.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
  </div>
</section>
