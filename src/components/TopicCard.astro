---
import { ICON_PATHS, type IconName } from "@/utils/icons";

interface Props {
  title: string;
  description: string;
  href: string;
  count: number;
  icon: IconName;
}

const { title, description, href, count, icon } = Astro.props;
---

<a
  href={href}
  class="group relative flex flex-col gap-3 rounded-2xl border border-ink-200 bg-white p-6 transition hover:-translate-y-1 hover:border-azure-300 hover:shadow-lg hover:shadow-azure-500/5 dark:border-ink-800 dark:bg-ink-900 dark:hover:border-azure-700"
>
  <div class="flex items-center justify-between">
    <span
      class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-azure-50 text-azure-600 transition group-hover:bg-azure-600 group-hover:text-white dark:bg-ink-800 dark:text-azure-400"
    >
      <svg
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.8"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d={ICON_PATHS[icon]}></path>
      </svg>
    </span>
    <span
      class="text-xs font-medium text-ink-400 dark:text-ink-500"
      >{count} {count === 1 ? "article" : "articles"}</span
    >
  </div>

  <h3 class="text-base font-semibold text-ink-900 dark:text-white">{title}</h3>
  <p class="text-sm text-ink-600 dark:text-ink-300">{description}</p>

  <span
    class="mt-auto inline-flex items-center gap-1 pt-1 text-sm font-semibold text-azure-600 dark:text-azure-400"
  >
    Explore
    <svg
      class="h-4 w-4 transition group-hover:translate-x-0.5"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6"></path>
    </svg>
  </span>
</a>
