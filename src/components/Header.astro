---
import { NAV_LINKS } from "@/consts";
import ThemeToggle from "./ThemeToggle.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header
  class="sticky top-0 z-40 border-b border-ink-200/70 bg-white/80 backdrop-blur-md dark:border-ink-800/70 dark:bg-ink-950/80"
>
  <nav
    class="mx-auto flex h-16 max-w-5xl items-center justify-between gap-4 px-4 sm:px-6"
    aria-label="Primary"
  >
    <a href="/" class="group flex items-center gap-2 font-semibold">
      <span
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-azure-600 to-teal-500 text-sm font-bold text-white"
        >RR</span
      >
      <span class="text-ink-900 dark:text-white">The Blog Home of Russ Rimmerman</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="hidden items-center gap-1 sm:flex">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isActive(link.href) ? "page" : undefined}
                class:list={[
                  "rounded-lg px-3 py-2 text-sm font-medium transition",
                  isActive(link.href)
                    ? "text-azure-600 dark:text-azure-400"
                    : "text-ink-600 hover:text-azure-600 dark:text-ink-300 dark:hover:text-azure-400",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <ThemeToggle />

      <a
        href="/search"
        aria-label="Search"
        aria-current={pathname.startsWith("/search") ? "page" : undefined}
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-ink-600 transition hover:text-azure-600 dark:text-ink-300 dark:hover:text-azure-400"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m21 21-4.3-4.3M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"></path>
        </svg>
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-ink-200 text-ink-600 sm:hidden dark:border-ink-700 dark:text-ink-300"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-ink-200/70 sm:hidden dark:border-ink-800/70"
  >
    <ul class="space-y-1 px-4 py-3">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
              class:list={[
                "block rounded-lg px-3 py-2 text-base font-medium transition",
                isActive(link.href)
                  ? "bg-azure-50 text-azure-600 dark:bg-ink-800 dark:text-azure-400"
                  : "text-ink-700 hover:bg-ink-50 dark:text-ink-200 dark:hover:bg-ink-800",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script is:inline>
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (!btn || !menu || btn.dataset.bound === "true") return;
    btn.dataset.bound = "true";
    btn.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!open));
    });
  }
  initMobileMenu();
  document.addEventListener("astro:after-swap", initMobileMenu);
</script>
