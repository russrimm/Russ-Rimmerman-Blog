---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { slugify } from "@/utils/tags";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tagMap = new Map<string, { label: string; posts: typeof posts }>();

  for (const post of posts) {
    for (const tag of post.data.tags) {
      const slug = slugify(tag);
      if (!tagMap.has(slug)) {
        tagMap.set(slug, { label: tag, posts: [] });
      }
      tagMap.get(slug)!.posts.push(post);
    }
  }

  return [...tagMap.entries()].map(([slug, { label, posts: tagPosts }]) => ({
    params: { tag: slug },
    props: {
      label,
      posts: tagPosts.sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
      ),
    },
  }));
}) satisfies GetStaticPaths;

const { label, posts } = Astro.props;
---

<BaseLayout
  title={`Posts tagged "${label}"`}
  description={`Blog posts about ${label} by Russ Rimmerman.`}
>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <a
        href="/tags"
        class="mb-4 inline-flex items-center gap-1 text-sm font-medium text-ink-500 transition hover:text-azure-600 dark:text-ink-400 dark:hover:text-azure-400"
      >
        &larr; All topics
      </a>
      <h1
        class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl dark:text-white"
      >
        <span class="text-ink-400 dark:text-ink-500">#</span>{label}
      </h1>
      <p class="mt-3 text-lg text-ink-600 dark:text-ink-300">
        {posts.length}
        {posts.length === 1 ? "post" : "posts"}
      </p>
    </header>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</BaseLayout>
