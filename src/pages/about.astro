---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SOCIALS } from "@/consts";

const skills = [
  "Microsoft Power Platform",
  "Power Apps & Power Automate",
  "Copilot Studio",
  "Azure Logic Apps",
  "Low-Code / No-Code Development",
  "Business Process Automation",
  "Microsoft Endpoint Manager (Intune)",
  "Azure Cloud Architecture",
];

const experience = [
  {
    role: "Principal Cloud Solution Architect — Power Platform",
    company: "Microsoft",
    period: "Jul 2022 – Present",
    location: "Houston, TX · Remote",
    summary:
      "Design, develop, and implement innovative low-code solutions on the Microsoft Power Platform and Azure. Lead successful projects, collaborate across cross-functional teams, and help clients optimize business processes to achieve more with less.",
  },
  {
    role: "Senior Customer Engineer (Premier Field Engineer)",
    company: "Microsoft",
    period: "Jun 2012 – Jun 2022",
    location: "Houston, TX · Hybrid",
    summary:
      "Specialized in Microsoft Endpoint Manager and Power Platform technologies, delivering high-impact engagements, training, health checks, risk assessments, and supportability reviews to customers across every vertical.",
  },
  {
    role: "Senior Technical Account Manager",
    company: "Microsoft",
    period: "Jun 2010 – Jun 2012",
    location: "Greater Houston · Hybrid",
    summary:
      "Connected customers directly to Microsoft product groups and expertise, deploying and supporting cutting-edge solutions while building strong relationships and driving successful outcomes.",
  },
];
---

<BaseLayout
  title="About"
  description="About Russ Rimmerman, Microsoft Cloud Solution Architect."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-8 sm:flex-row sm:items-center">
      <div
        class="flex h-28 w-28 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-azure-600 to-teal-500 text-4xl font-bold text-white"
        aria-hidden="true"
      >
        RR
      </div>
      <div>
        <h1
          class="text-balance text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl dark:text-white"
        >
          Russ Rimmerman
        </h1>
        <p class="mt-2 text-lg text-azure-600 dark:text-azure-400">
          Principal Cloud Solution Architect · Microsoft
        </p>
      </div>
    </div>

    <div class="prose prose-lg mt-10 max-w-none dark:prose-invert">
      <p>
        I'm a Principal Cloud Solution Architect at Microsoft with over 30 years
        of experience across a wide range of information technology domains. As a
        Power Platform expert, I design, develop, and implement innovative
        solutions tailored to each client's unique needs using low-code tools
        like Copilot Studio, Power Apps, Power Automate, and Azure Logic Apps.
      </p>
      <p>
        My mission is to empower clients to optimize their business processes
        through low-code development — helping them achieve more with less and
        improve their outcomes through increased efficiency and productivity. I
        have a strong track record of leading successful projects, collaborating
        across cross-functional teams, and delivering high-quality solutions that
        exceed customer expectations.
      </p>
      <p>
        I've co-authored two Microsoft Press e-books in the Endpoint Management
        space, sharing insights and best practices with the wider community.
        This site is where I continue that — sharing what I'm learning and the
        projects I build along the way. I'm passionate about making a positive
        difference in my clients' businesses through the power of Microsoft's
        cutting-edge technologies.
      </p>
    </div>

    <div class="mt-12">
      <h2 class="text-xl font-semibold text-ink-900 dark:text-white">
        Experience
      </h2>
      <p class="mt-1 text-sm text-ink-500 dark:text-ink-400">
        16+ years at Microsoft
      </p>
      <ol class="mt-6 space-y-8 border-l border-ink-200 pl-6 dark:border-ink-800">
        {
          experience.map((job) => (
            <li class="relative">
              <span
                class="absolute top-1.5 -left-[1.65rem] h-3 w-3 rounded-full bg-azure-500 ring-4 ring-white dark:ring-ink-950"
                aria-hidden="true"
              />
              <h3 class="font-semibold text-ink-900 dark:text-white">
                {job.role}
              </h3>
              <p class="text-sm text-azure-600 dark:text-azure-400">
                {job.company} · {job.period}
              </p>
              <p class="text-xs text-ink-500 dark:text-ink-400">
                {job.location}
              </p>
              <p class="mt-2 text-ink-700 dark:text-ink-300">{job.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="mt-12">
      <h2 class="text-xl font-semibold text-ink-900 dark:text-white">
        What I work with
      </h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <li class="rounded-lg border border-ink-200 bg-white px-3 py-1.5 text-sm text-ink-700 dark:border-ink-800 dark:bg-ink-900 dark:text-ink-200">
              {skill}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-12 flex flex-wrap gap-3">
      <a
        href={SOCIALS.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-ink-300 px-5 py-3 text-sm font-semibold text-ink-700 transition hover:border-azure-400 hover:text-azure-600 dark:border-ink-700 dark:text-ink-200 dark:hover:border-azure-500 dark:hover:text-azure-400"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
          ><path
            d="M4.98 3.5A2.5 2.5 0 100 3.51 2.5 2.5 0 004.98 3.5zM.24 8.02h4.5V24H.24V8.02zM8.24 8.02h4.31v2.18h.06c.6-1.14 2.07-2.34 4.26-2.34C21.6 7.86 24 10.1 24 14.6V24h-4.5v-8.3c0-1.98-.04-4.52-2.76-4.52-2.76 0-3.18 2.16-3.18 4.38V24H8.24V8.02z"
          ></path></svg
        >
        Connect on LinkedIn
      </a>
      <a
        href={SOCIALS.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-ink-300 px-5 py-3 text-sm font-semibold text-ink-700 transition hover:border-azure-400 hover:text-azure-600 dark:border-ink-700 dark:text-ink-200 dark:hover:border-azure-500 dark:hover:text-azure-400"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
          ><path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.48l-.01-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.9 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.35 9.35 0 015 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.79-4.57 5.04.36.32.68.94.68 1.9l-.01 2.82c0 .27.18.59.69.48A10.02 10.02 0 0022 12.25C22 6.58 17.52 2 12 2z"
          ></path></svg
        >
        Follow on GitHub
      </a>
    </div>
  </div>
</BaseLayout>
