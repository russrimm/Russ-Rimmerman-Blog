---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import { ICON_PATHS } from "@/utils/icons";
import { slugify } from "@/utils/tags";
import { readingTimeLabel } from "@/utils/readingTime";
import { TOPICS, getTopicPosts } from "@/utils/topics";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return TOPICS.map((topic) => ({
    topic,
    posts: getTopicPosts(topic, posts),
  }))
    .filter(({ posts: topicPosts }) => topicPosts.length > 0)
    .map(({ topic, posts: topicPosts }) => ({
      params: { topic: topic.slug },
      props: { topic, posts: topicPosts },
    }));
}) satisfies GetStaticPaths;

const { topic, posts } = Astro.props;

// Related topics: other hubs that also have published content.
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedTopics = TOPICS.filter(
  (t) => t.slug !== topic.slug && getTopicPosts(t, allPosts).length > 0,
).slice(0, 3);
---

<BaseLayout
  title={topic.title}
  description={topic.description}
>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6">
    <a
      href="/topics"
      class="mb-6 inline-flex items-center gap-1 text-sm font-medium text-ink-500 transition hover:text-azure-600 dark:text-ink-400 dark:hover:text-azure-400"
    >
      &larr; All topics
    </a>

    <header
      class="relative overflow-hidden rounded-3xl border border-ink-200 bg-white p-7 sm:p-9 dark:border-ink-800 dark:bg-ink-900"
    >
      <div
        class="absolute -top-20 -right-16 -z-0 h-56 w-56 rounded-full bg-azure-500/10 blur-3xl"
        aria-hidden="true"
      >
      </div>

      <div class="relative flex flex-col gap-5">
        <div class="flex items-center gap-4">
          <span
            class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-azure-600 to-teal-500 text-white"
            aria-hidden="true"
          >
            <svg
              class="h-7 w-7"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.8"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d={ICON_PATHS[topic.icon]}></path>
            </svg>
          </span>
          <div>
            <h1
              class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl dark:text-white"
            >
              {topic.title}
            </h1>
            <p class="text-sm font-medium text-ink-500 dark:text-ink-400">
              {posts.length}
              {posts.length === 1 ? "article" : "articles"}
            </p>
          </div>
        </div>

        <p class="max-w-2xl text-lg text-ink-600 dark:text-ink-300">
          {topic.intro}
        </p>

        <ul class="grid gap-2 sm:grid-cols-2">
          {
            topic.focus.map((item) => (
              <li class="flex items-start gap-2 text-sm text-ink-700 dark:text-ink-300">
                <svg
                  class="mt-0.5 h-4 w-4 shrink-0 text-teal-500"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>

        <ul class="flex flex-wrap gap-2">
          {
            topic.tags.map((tag) => (
              <li>
                <a
                  href={`/tags/${slugify(tag)}`}
                  class="inline-flex items-center rounded-full border border-azure-200 bg-azure-50 px-2.5 py-0.5 text-xs font-medium text-azure-700 transition hover:border-azure-400 hover:bg-azure-100 dark:border-ink-700 dark:bg-ink-800 dark:text-azure-300 dark:hover:border-azure-500"
                >
                  #{tag}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </header>

    <section class="mt-10">
      <div class="mb-6 flex items-baseline justify-between gap-4">
        <h2 class="text-lg font-semibold text-ink-900 dark:text-white">
          Articles about {topic.title}
        </h2>
        <p
          class="flex items-center gap-1.5 text-xs font-medium text-ink-500 dark:text-ink-400"
        >
          <svg
            class="h-3.5 w-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 5h13M3 12h9m-9 7h13M17 8l4 4-4 4"></path>
          </svg>
          Newest first
        </p>
      </div>

      <ol class="relative ms-2 border-s border-ink-200 sm:ms-3 dark:border-ink-800">
        {
          posts.map((post) => {
            const url = `/blog/${post.id}`;
            const readTime = readingTimeLabel(post.body);
            const primaryTag = post.data.tags[0];
            return (
              <li class="group relative ms-6 pb-9 last:pb-0 sm:ms-8">
                <span
                  class="absolute -start-[calc(1.5rem+0.5rem)] top-1.5 h-3.5 w-3.5 rounded-full border-2 border-white bg-azure-500 ring-1 ring-ink-200 transition group-hover:scale-125 group-hover:bg-azure-600 sm:-start-[calc(2rem+0.5rem)] dark:border-ink-950 dark:ring-ink-800"
                  aria-hidden="true"
                />
                <div class="relative rounded-2xl border border-transparent px-4 py-3 transition group-hover:border-ink-200 group-hover:bg-white group-hover:shadow-sm dark:group-hover:border-ink-800 dark:group-hover:bg-ink-900">
                  <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-ink-500 dark:text-ink-400">
                    <span class="font-semibold text-azure-600 dark:text-azure-400">
                      <FormattedDate date={post.data.pubDate} />
                    </span>
                    {readTime && <span aria-hidden="true">·</span>}
                    {readTime && <span>{readTime}</span>}
                    {primaryTag && (
                      <>
                        <span aria-hidden="true">·</span>
                        <span>{primaryTag}</span>
                      </>
                    )}
                  </div>
                  <h3 class="mt-1.5 text-lg font-semibold text-ink-900 transition group-hover:text-azure-600 dark:text-white dark:group-hover:text-azure-400">
                    <a href={url} class="after:absolute after:inset-0">
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="mt-1 line-clamp-2 max-w-2xl text-sm text-ink-600 dark:text-ink-300">
                    {post.data.description}
                  </p>
                </div>
              </li>
            );
          })
        }
      </ol>
    </section>

    {
      relatedTopics.length > 0 && (
        <section class="mt-14 border-t border-ink-200/70 pt-10 dark:border-ink-800/70">
          <h2 class="text-lg font-semibold text-ink-900 dark:text-white">
            Explore related topics
          </h2>
          <ul class="mt-4 flex flex-wrap gap-3">
            {relatedTopics.map((t) => (
              <li>
                <a
                  href={`/topics/${t.slug}`}
                  class="inline-flex items-center gap-2 rounded-full border border-ink-200 bg-white px-4 py-2 text-sm font-medium text-ink-700 transition hover:border-azure-400 hover:text-azure-600 dark:border-ink-800 dark:bg-ink-900 dark:text-ink-200 dark:hover:border-azure-500 dark:hover:text-azure-400"
                >
                  {t.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </div>
</BaseLayout>
