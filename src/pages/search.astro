---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Search"
  description="Search articles on AI, Copilot, Azure, Power Platform, identity, and automation by Russ Rimmerman."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header class="mb-8">
      <h1
        class="text-balance text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl dark:text-white"
      >
        Search
      </h1>
      <p class="mt-3 text-lg text-ink-600 dark:text-ink-300">
        Find articles by title, summary, or topic.
      </p>
    </header>

    <form role="search" data-search-form>
      <label for="search-input" class="sr-only">Search articles</label>
      <div class="relative">
        <svg
          class="pointer-events-none absolute top-1/2 left-4 h-5 w-5 -translate-y-1/2 text-ink-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m21 21-4.3-4.3M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"></path>
        </svg>
        <input
          id="search-input"
          type="search"
          name="q"
          autocomplete="off"
          placeholder="Search for Copilot, Azure, agents…"
          class="w-full rounded-xl border border-ink-300 bg-white py-3.5 pr-4 pl-12 text-base text-ink-900 placeholder:text-ink-400 focus:border-azure-500 focus:ring-2 focus:ring-azure-500/30 focus:outline-none dark:border-ink-700 dark:bg-ink-900 dark:text-white"
        />
      </div>
    </form>

    <p
      class="mt-6 text-sm text-ink-500 dark:text-ink-400"
      data-search-status
      aria-live="polite"
    >
    </p>

    <div class="mt-2 divide-y divide-ink-200/70 dark:divide-ink-800/70" data-search-results>
    </div>
  </div>
</BaseLayout>

<script>
  interface Entry {
    title: string;
    description: string;
    tags: string[];
    url: string;
    pubDate: string;
    readingTime: string;
  }

  const dateFmt = new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

  const escapeHtml = (value: string) =>
    value.replace(
      /[&<>"']/g,
      (c) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c] as string,
    );

  function initSearch() {
    const form = document.querySelector<HTMLFormElement>("[data-search-form]");
    const input = document.querySelector<HTMLInputElement>("#search-input");
    const results = document.querySelector<HTMLElement>("[data-search-results]");
    const status = document.querySelector<HTMLElement>("[data-search-status]");
    if (!form || !input || !results || !status) return;

    let entries: Entry[] = [];

    form.addEventListener("submit", (e) => e.preventDefault());

    const render = (query: string) => {
      const q = query.trim().toLowerCase();
      if (!q) {
        results.innerHTML = "";
        status.textContent = `Start typing to search ${entries.length} articles.`;
        return;
      }
      const matches = entries.filter((entry) => {
        const haystack = [
          entry.title,
          entry.description,
          entry.tags.join(" "),
        ]
          .join(" ")
          .toLowerCase();
        return q.split(/\s+/).every((term) => haystack.includes(term));
      });

      status.textContent = matches.length
        ? `${matches.length} ${matches.length === 1 ? "result" : "results"} for “${query.trim()}”`
        : `No results for “${query.trim()}”. Try a different term.`;

      results.innerHTML = matches
        .map((entry) => {
          const date = dateFmt.format(new Date(entry.pubDate));
          const tag = entry.tags[0]
            ? `<span aria-hidden="true">·</span><span class="text-azure-600 dark:text-azure-400">${escapeHtml(entry.tags[0])}</span>`
            : "";
          return `
            <article class="group relative py-5">
              <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-ink-500 dark:text-ink-400">
                <span>${date}</span>
                <span aria-hidden="true">·</span>
                <span>${escapeHtml(entry.readingTime)}</span>
                ${tag}
              </div>
              <h2 class="mt-1.5 text-lg font-semibold text-ink-900 transition group-hover:text-azure-600 dark:text-white dark:group-hover:text-azure-400">
                <a href="${entry.url}" class="after:absolute after:inset-0">${escapeHtml(entry.title)}</a>
              </h2>
              <p class="mt-1 line-clamp-2 text-sm text-ink-600 dark:text-ink-300">${escapeHtml(entry.description)}</p>
            </article>`;
        })
        .join("");
    };

    fetch("/search.json")
      .then((r) => r.json())
      .then((data: Entry[]) => {
        entries = data;
        const params = new URLSearchParams(window.location.search);
        const initial = params.get("q") ?? "";
        if (initial) input.value = initial;
        render(input.value);
        input.focus();
      })
      .catch(() => {
        status.textContent = "Search is unavailable right now.";
      });

    input.addEventListener("input", () => render(input.value));
  }

  initSearch();
  document.addEventListener("astro:after-swap", initSearch);
</script>
