---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import FeaturedPost from "@/components/FeaturedPost.astro";
import PostCard from "@/components/PostCard.astro";
import NewsletterSignup from "@/components/NewsletterSignup.astro";
import { TOPICS, getTopicPosts } from "@/utils/topics";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost =
  posts.find((p) => p.data.featured) ?? posts[0] ?? undefined;
const recentPosts = posts
  .filter((p) => p.id !== featuredPost?.id)
  .slice(0, 6);

// Curated topic pathways. Only hubs with real content are rendered, so we
// never link readers to an empty destination.
const topics = TOPICS.map((topic) => ({
  ...topic,
  count: getTopicPosts(topic, posts).length,
})).filter((topic) => topic.count > 0);
---

<BaseLayout>
  <div class="mx-auto max-w-5xl px-4 pt-10 sm:px-6 sm:pt-14">
    <!-- Featured post leads the page -->
    {featuredPost && <FeaturedPost post={featuredPost} />}

    <!-- Latest posts grid -->
    {
      recentPosts.length > 0 && (
        <section class="mt-12">
          <div class="mb-6 flex items-end justify-between gap-4">
            <h2 class="text-2xl font-bold tracking-tight text-ink-900 dark:text-white">
              Latest posts
            </h2>
            <a
              href="/blog"
              class="shrink-0 text-sm font-medium text-azure-600 hover:underline dark:text-azure-400"
            >
              All posts &rarr;
            </a>
          </div>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {recentPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        </section>
      )
    }

    <!-- Return-value hooks: subscribe + explore topics -->
    <section class="mt-14 grid gap-6 pb-16 md:grid-cols-2">
      <NewsletterSignup compact />

      {
        topics.length > 0 && (
          <div class="rounded-2xl border border-ink-200 bg-white p-5 dark:border-ink-800 dark:bg-ink-900">
            <div class="flex items-center justify-between">
              <h2 class="text-sm font-semibold text-ink-900 dark:text-white">
                Explore topics
              </h2>
              <a
                href="/topics"
                class="text-xs font-medium text-azure-600 hover:underline dark:text-azure-400"
              >
                All
              </a>
            </div>
            <ul class="mt-3 space-y-1">
              {topics.map((topic) => (
                <li>
                  <a
                    href={`/topics/${topic.slug}`}
                    class="group flex items-center justify-between rounded-lg px-2 py-1.5 text-sm text-ink-700 transition hover:bg-ink-50 hover:text-azure-600 dark:text-ink-200 dark:hover:bg-ink-800 dark:hover:text-azure-400"
                  >
                    <span>{topic.title}</span>
                    <span class="rounded-full bg-ink-100 px-2 py-0.5 text-xs text-ink-500 group-hover:bg-azure-100 group-hover:text-azure-700 dark:bg-ink-800 dark:text-ink-400 dark:group-hover:bg-ink-700">
                      {topic.count}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </section>
  </div>
</BaseLayout>


