---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NewsletterSignup from "@/components/NewsletterSignup.astro";
import { SOCIALS, AUTHOR } from "@/consts";
---

<BaseLayout
  title="Contact"
  description="Get in touch with Russ Rimmerman — connect on LinkedIn, GitHub, or subscribe to the newsletter."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <h1
        class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl dark:text-white"
      >
        Get in touch
      </h1>
      <p class="mt-3 text-lg text-ink-600 dark:text-ink-300">
        I'm always happy to talk cloud architecture, AI, or a good technical
        challenge. Reach out through any of the channels below.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2">
      <a
        href={SOCIALS.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 rounded-2xl border border-ink-200 bg-white p-5 transition hover:border-azure-300 dark:border-ink-800 dark:bg-ink-900 dark:hover:border-azure-700"
      >
        <span
          class="flex h-11 w-11 items-center justify-center rounded-xl bg-azure-50 text-azure-600 dark:bg-ink-800 dark:text-azure-400"
        >
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"
            ><path
              d="M4.98 3.5A2.5 2.5 0 100 3.51 2.5 2.5 0 004.98 3.5zM.24 8.02h4.5V24H.24V8.02zM8.24 8.02h4.31v2.18h.06c.6-1.14 2.07-2.34 4.26-2.34C21.6 7.86 24 10.1 24 14.6V24h-4.5v-8.3c0-1.98-.04-4.52-2.76-4.52-2.76 0-3.18 2.16-3.18 4.38V24H8.24V8.02z"
            ></path></svg
          >
        </span>
        <span>
          <span class="block font-semibold text-ink-900 dark:text-white"
            >LinkedIn</span
          >
          <span class="block text-sm text-ink-500 dark:text-ink-400"
            >/in/russrimm</span
          >
        </span>
      </a>

      <a
        href={SOCIALS.github}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 rounded-2xl border border-ink-200 bg-white p-5 transition hover:border-azure-300 dark:border-ink-800 dark:bg-ink-900 dark:hover:border-azure-700"
      >
        <span
          class="flex h-11 w-11 items-center justify-center rounded-xl bg-azure-50 text-azure-600 dark:bg-ink-800 dark:text-azure-400"
        >
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"
            ><path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.48l-.01-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.9 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.35 9.35 0 015 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.79-4.57 5.04.36.32.68.94.68 1.9l-.01 2.82c0 .27.18.59.69.48A10.02 10.02 0 0022 12.25C22 6.58 17.52 2 12 2z"
            ></path></svg
          >
        </span>
        <span>
          <span class="block font-semibold text-ink-900 dark:text-white"
            >GitHub</span
          >
          <span class="block text-sm text-ink-500 dark:text-ink-400"
            >@russrimm</span
          >
        </span>
      </a>

      <a
        href={`mailto:${AUTHOR.email}`}
        class="group flex items-center gap-4 rounded-2xl border border-ink-200 bg-white p-5 transition hover:border-azure-300 sm:col-span-2 dark:border-ink-800 dark:bg-ink-900 dark:hover:border-azure-700"
      >
        <span
          class="flex h-11 w-11 items-center justify-center rounded-xl bg-azure-50 text-azure-600 dark:bg-ink-800 dark:text-azure-400"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 8l9 6 9-6M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z"
            ></path></svg
          >
        </span>
        <span>
          <span class="block font-semibold text-ink-900 dark:text-white"
            >Email</span
          >
          <span class="block text-sm text-ink-500 dark:text-ink-400"
            >{AUTHOR.email}</span
          >
        </span>
      </a>
    </div>

    <div class="mt-10">
      <NewsletterSignup />
    </div>
  </div>
</BaseLayout>
