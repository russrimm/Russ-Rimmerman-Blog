---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="The page you're looking for doesn't exist.">
  <div
    class="mx-auto flex max-w-3xl flex-col items-center px-4 py-24 text-center sm:px-6"
  >
    <p class="text-7xl font-bold text-azure-600 dark:text-azure-400">404</p>
    <h1 class="mt-4 text-2xl font-bold text-ink-900 dark:text-white">
      This page took a different route.
    </h1>
    <p class="mt-3 text-ink-600 dark:text-ink-300">
      The page you're looking for doesn't exist or has moved.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/"
        class="rounded-lg bg-azure-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-azure-700"
      >
        Back home
      </a>
      <a
        href="/blog"
        class="rounded-lg border border-ink-300 px-5 py-3 text-sm font-semibold text-ink-700 transition hover:border-azure-400 hover:text-azure-600 dark:border-ink-700 dark:text-ink-200 dark:hover:border-azure-500 dark:hover:text-azure-400"
      >
        Read the blog
      </a>
    </div>
  </div>
</BaseLayout>
