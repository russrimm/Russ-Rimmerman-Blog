{
  "name": "russrimmerman-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal blog and portfolio of Russ Rimmerman, Microsoft Cloud Solution Architect.",
  "author": "Russ Rimmerman",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev --host",
    "cms": "KEYSTATIC=true astro dev --host",
    "build": "astro check && astro build",
    "preview": "astro preview --host",
    "astro": "astro",
    "hero": "node --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/generate-hero.mjs",
    "format": "prettier --write \"**/*.{astro,ts,js,mjs,css,md,mdx,json}\""
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@keystatic/astro": "^5.2.0",
    "@keystatic/core": "^0.5.50",
    "astro": "^7.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@azure/identity": "^4.13.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "reading-time": "^1.5.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
  }
}
